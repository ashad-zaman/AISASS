{
  "name": "aisass-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose -f infrastructure/docker/docker-compose.yml up",
    "build": "npm run build --workspace=apps/backend && npm run build --workspace=apps/frontend",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "backend": "npm run start:dev -w apps/backend",
    "frontend": "npm run dev -w apps/frontend"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
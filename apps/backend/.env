# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/aisass_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secrets
JWT_SECRET=dev-jwt-secret-min-32-characters-for-development
JWT_REFRESH_SECRET=dev-refresh-secret-min-32-characters-for-development
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI (add your key here for testing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Stripe (add your keys here for testing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# App
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# Vector
VECTOR_DIMENSION=1536
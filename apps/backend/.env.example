# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aisass_db

# Database URL (used by Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aisass_db

# Alternative: Use connection string format
# DATABASE_URL=postgresql://username:password@host:port/database?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Secrets (IMPORTANT: change in production - must be at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI (get from https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Stripe (get from https://dashboard.stripe.com)
# Test keys: start with sk_test_ / whsec_
# Live keys: start with sk_live_ / whsec_
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_PRO=price_your_pro_price_id
STRIPE_PRICE_ID_TEAM=price_your_team_price_id

# Storage (local/s3/gcs)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
# For S3:
AWS_REGION=us-east-1
AWS_S3_BUCKET=aisass-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# For GCS:
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
GCS_PRIVATE_KEY=
GCS_CLIENT_EMAIL=

# App Configuration
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# Vector (embedding dimension for text-embedding-3-small)
VECTOR_DIMENSION=1536

# Database Connection Pool (optional - for production)
# DATABASE_POOL_TIMEOUT=10
# DATABASE_MAX_CONNECTIONS=20
# DATABASE_MIN_CONNECTIONS=5